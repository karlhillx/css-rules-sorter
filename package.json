{
  "name": "css-rules-sorter",
  "version": "1.0.1",
  "description": "PostCSS-based CSS rules sorter that alphabetically sorts selectors and media queries",
  "main": "index.js",
  "types": "index.d.ts",
  "scripts": {
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "npm test && npm run lint"
  },
  "keywords": [
    "css",
    "postcss",
    "sorter",
    "css-sorter",
    "stylesheet"
  ],
  "author": "Karl Hill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/karlhillx/css-rules-sorter.git"
  },
  "dependencies": {
    "postcss": "^8.4.0",
    "postcss-sort-media-queries": "^5.2.0"
  },
  "devDependencies": {
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.15.0",
    "jest": "^29.0.0",
    "prettier": "^3.8.1"
  }
}
