{
  "name": "@karlhillx/css-rules-sorter",
  "version": "1.2.0",
  "description": "Professional CSS management engine for PostCSS. Advanced BEM sorting, shorthand expansion/collapse, and cascade layer management with full TypeScript support.",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "test": "jest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "css",
    "postcss",
    "sorter",
    "css-sorter",
    "stylesheet",
    "bem",
    "typescript"
  ],
  "author": "Karl Hill",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/karlhillx/css-rules-sorter.git"
  },
  "dependencies": {
    "postcss-sort-media-queries": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jest": "^29.0.0",
    "globals": "^15.0.0",
    "jest": "^29.7.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsup": "^8.0.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1"
  }
}
